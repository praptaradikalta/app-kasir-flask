<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KasirPro - Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg: #f3efe9;
      --surface: #dceee7;
      --brand: #1f6f57;
      --brand-dark: #165543;
      --text: #1e1e1e;
      --muted: #6f6558;
      --line: #d8ccb8;
      --white: #ffffff;
      --accent: #d9923b;
      --shadow: 0 8px 24px rgba(0,0,0,.12);
      --radius: 14px;
      --bottom-nav-h: 68px;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: "Plus Jakarta Sans", sans-serif;
    }

    body {
      min-height: 100vh;
      padding-bottom: calc(var(--bottom-nav-h) + 16px);
    }

    h1, h2, h3 {
      font-family: "Outfit", sans-serif;
      margin: 0;
      line-height: 1.05;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    /* HEADER */
    .mobile-nav {
      position: sticky;
      top: 0;
      z-index: 120;
      background: var(--brand);
      color: var(--white);
      min-height: 76px;
      display: flex;
      align-items: flex-end;
      gap: 12px;
      padding: 12px 16px 14px;
      box-shadow: 0 2px 0 rgba(0,0,0,.04);
    }

    #menuToggle {
      flex: 0 0 auto;
      width: 42px;
      height: 42px;
      border: none;
      border-radius: 10px;
      background: rgba(255,255,255,.12);
      color: var(--white);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: transform .18s ease, background .18s ease;
      margin: 0;
      padding: 0;
    }

    #menuToggle:hover,
    #menuToggle:active {
      background: rgba(255,255,255,.2);
      transform: scale(.98);
    }

    #menuToggle svg {
      width: 24px;
      height: 24px;
      display: block;
    }

    .mobile-nav h1 {
      font-size: clamp(2rem, 7vw, 2.4rem);
      font-weight: 800;
      letter-spacing: -.04em;
      line-height: .95;
      margin: 0;
      transform: translateY(2px);
    }

    /* MAIN */
    main {
      padding: 16px;
    }

    section {
      background: var(--surface);
      padding: 18px 16px;
      border-radius: var(--radius);
      margin-bottom: 16px;
    }

    section h2 {
      font-size: 1.1rem;
      margin-bottom: 18px;
      font-weight: 800;
    }

    section p {
      font-size: 1rem;
      font-weight: 700;
      margin: 0 0 14px;
    }

    section p:last-child {
      margin-bottom: 0;
    }

    /* DRAWER */
    .drawer {
      position: fixed;
      inset: 0 auto 0 0;
      width: min(82vw, 280px);
      background: #fffaf0;
      transform: translateX(-100%);
      transition: transform .28s ease;
      z-index: 220;
      box-shadow: 10px 0 30px rgba(0,0,0,.18);
      display: flex;
      flex-direction: column;
      padding: 20px 16px;
    }

    .drawer.open {
      transform: translateX(0);
    }

    .drawer-head {
      padding-bottom: 14px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 14px;
    }

    .drawer-head h2 {
      color: var(--brand);
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -.03em;
    }

    .drawer-head p {
      margin: 6px 0 0;
      color: var(--muted);
      font-size: .9rem;
      font-weight: 600;
    }

    .drawer nav {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .drawer nav a {
      display: flex;
      align-items: center;
      min-height: 46px;
      padding: 0 14px;
      border-radius: 12px;
      color: var(--brand-dark);
      font-weight: 700;
      transition: background .2s ease, transform .2s ease, color .2s ease;
    }

    .drawer nav a:hover,
    .drawer nav a:focus {
      background: #e7f4ef;
      transform: translateX(2px);
      outline: none;
    }

    .drawer nav a.active {
      background: var(--brand);
      color: var(--white);
    }

    .backdrop {
      position: fixed;
      inset: 0;
      background: rgba(13, 18, 16, 0.42);
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s ease;
      z-index: 210;
      backdrop-filter: blur(2px);
    }

    .backdrop.show {
      opacity: 1;
      pointer-events: auto;
    }

    /* BOTTOM NAV */
    .bottom-nav {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 140;
      height: var(--bottom-nav-h);
      background: rgba(255,250,240,.95);
      backdrop-filter: blur(10px);
      border-top: 1px solid var(--line);
      box-shadow: 0 -4px 16px rgba(0,0,0,.08);
      display: grid;
      grid-template-columns: repeat(5, 1fr);
    }

    .bottom-nav a {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 10px 4px 8px;
      color: var(--muted);
      font-size: .78rem;
      font-weight: 700;
      line-height: 1.1;
      transition: color .2s ease, background .2s ease;
    }

    .bottom-nav a.active {
      color: var(--brand);
    }

    .bottom-nav a.active::before {
      content: "";
      position: absolute;
      top: 0;
      left: 12%;
      right: 12%;
      height: 3px;
      border-radius: 999px;
      background: var(--brand);
    }

    .bottom-nav a:hover {
      background: rgba(31,111,87,.05);
    }

    @media (min-width: 768px) {
      body {
        max-width: 460px;
        margin: 0 auto;
        box-shadow: 0 0 0 1px rgba(0,0,0,.04);
      }

      .bottom-nav,
      .mobile-nav {
        max-width: 460px;
        margin: 0 auto;
      }
    }
  </style>
</head>
<body>
  <header class="mobile-nav">
    <button id="menuToggle" aria-label="Buka menu" aria-expanded="false" aria-controls="drawer">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7H20" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
        <path d="M4 12H20" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
        <path d="M4 17H20" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
      </svg>
    </button>
    <h1>KasirPro</h1>
  </header>

  <aside id="drawer" class="drawer" aria-hidden="true">
    <div class="drawer-head">
      <h2>KasirPro</h2>
      <p>Menu navigasi</p>
    </div>

    <nav>
      <a href="/dashboard" class="active">Dashboard</a>
      <a href="/produk">Produk</a>
      <a href="/penjualan">Penjualan</a>
      <a href="/laporan">Laporan</a>
      <a href="/pengaturan">Pengaturan</a>
    </nav>
  </aside>

  <div id="backdrop" class="backdrop"></div>

  <main>
    <section>
      <h2>Ringkasan Hari Ini</h2>
      <p>Omzet Hari Ini: Rp 0</p>
      <p>Cash di Laci: Rp 0</p>
    </section>
  </main>

  <nav class="bottom-nav">
    <a href="/dashboard" class="active">Dashboard</a>
    <a href="/produk">Produk</a>
    <a href="/penjualan">Penjualan</a>
    <a href="/laporan">Laporan</a>
    <a href="/pengaturan">Pengaturan</a>
  </nav>

  <script>
    const menuToggle = document.getElementById('menuToggle');
    const drawer = document.getElementById('drawer');
    const backdrop = document.getElementById('backdrop');
    const allNavLinks = document.querySelectorAll('.bottom-nav a, .drawer nav a');

    function openDrawer() {
      drawer.classList.add('open');
      backdrop.classList.add('show');
      drawer.setAttribute('aria-hidden', 'false');
      menuToggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('open');
      backdrop.classList.remove('show');
      drawer.setAttribute('aria-hidden', 'true');
      menuToggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    function toggleDrawer() {
      const isOpen = drawer.classList.contains('open');
      if (isOpen) closeDrawer();
      else openDrawer();
    }

    menuToggle.addEventListener('click', toggleDrawer);
    backdrop.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDrawer();
    });

    // Tandai menu aktif otomatis berdasarkan URL
    const currentPath = window.location.pathname.replace(/\/+$/, '') || '/';

    allNavLinks.forEach(link => {
      const url = new URL(link.href, window.location.origin);
      const linkPath = url.pathname.replace(/\/+$/, '') || '/';
      link.classList.toggle('active', linkPath === currentPath);
    });
  </script>
</body>
</html>

