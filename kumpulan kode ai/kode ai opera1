              </div>
              <span class="arrow">→</span>
            </a>

            <a href="#" class="quick-item">
              <div>
                <strong>Laporan</strong>
                <small>Analisis data penjualan</small>
              </div>
              <span class="arrow">→</span>
            </a>

            <a href="#" class="quick-item">
              <div>
                <strong>Pengaturan</strong>
