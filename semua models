# 6. Resep
class Resep(db.Model):
    __tablename__ = 'resep'
    id = db.Column(db.Integer, primary_key=True)
    produk_id = db.Column(db.Integer, db.ForeignKey('produk.id'), unique=True)
    nama_resep = db.Column(db.String(100))
    porsi_hasil = db.Column(db.Integer, default=1)  # 1 batch jadi brp porsi
    detail = db.relationship('ResepDetail', backref='resep', lazy=True, cascade='all, delete-orphan')

    def __repr__(self):
        return f'<Resep {self.nama_resep}>'

