    kembalian = db.Column(db.Integer, default=0)
    status = db.Column(db.String(20), default='belum_bayar')  # belum_bayar, lunas, hutang
    detail = db.relationship('PenjualanDetail', backref='penjualan', lazy=True, cascade='all, delete-orphan')
    buku_kas = db.relationship('BukuKas', backref='penjualan', uselist=False, lazy=True)

    def __repr__(self):
        return f'<Penjualan {self.id}>'


# 10. Penjualan Detail
class PenjualanDetail(db.Model):
    __tablename__ = 'penjualan_detail'
    id = db.Column(db.Integer, primary_key=True)
    penjualan_id = db.Column(db.Integer, db.ForeignKey('penjualan.id'), nullable=False)
    produk_id = db.Column(db.Integer, db.ForeignKey('produk.id'), nullable=False)
    qty = db.Column(db.Integer, nullable=False)
    harga_jual = db.Column(db.Integer)  # harga saat jual
    catatan = db.Column(db.String(200))  # "Pedas, no seledri"
    subtotal = db.Column(db.Integer)
    laba = db.Column(db.Integer, default=0)  # Auto hitung: (harga_jual - hpp) * qty
    
    def hitung(self):
        self.subtotal = self.qty * self.harga_jual
        hpp = self.produk.harga_beli_supplier if self.produk.is_konsinyasi else self.produk.harga_beli
        self.laba = (self.harga_jual - hpp) * self.qty

    def __repr__(self):
        return f'<PenjualanDetail {self.id}>'

